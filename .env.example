# ==============================================================================
# SPARTACUS BUBBLE AI AGENT - CONSOLIDATED ENVIRONMENT TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE BACKEND SETTINGS (backend/ directory)
# ------------------------------------------------------------------------------
# The port on which the Express server runs (default: 8080 or 8001).
PORT=8080

# Environment stage: 'development' or 'production'.
NODE_ENV=development

# Full public facing URL of the backend service (for webhooks callback).
BACKEND_URL=http://localhost:8080

# Public facing URL of the frontend dashboard.
FRONT_END_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# 2. DATABASE & CACHING
# ------------------------------------------------------------------------------
# PostgreSQL Connection URL (Used by Prisma ORM).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spartacus?schema=public

# Redis Connection URL (Used for API rate limiting / caching).
REDIS_URL=redis://localhost:6379

# Redis Authentication (If configured on Redis service).
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------
# Keys used to sign JSON Web Tokens. Must be a strong, random key in production.
JWT_SECRET_TOKEN=your_jwt_secret_token_here
JWT_REFRESH_TOKEN=your_jwt_refresh_token_here

# Expiration policies for JWT sessions.
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth credentials (for login features).
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8080/api/user/auth/google/callback

# ------------------------------------------------------------------------------
# 4. EXTERNAL INTEGRATIONS
# ------------------------------------------------------------------------------
# SendGrid transactional email configuration.
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=hi@spartacusbubble.co.uk

# Rezgo ticketing & booking API configuration.
REZGO_CID=your_rezgo_cid_here
REZGO_API_KEY=your_rezgo_api_key_here

# AI Engine API Endpoint (Points to the FastAPI AI service).
AI_ENGINE_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# 5. CORE AI SETTINGS (ai/ directory)
# ------------------------------------------------------------------------------
# OpenAI developer API Key (Must support gpt-4o-mini and text-embedding-3-small).
OPENAI_API_KEY=your_openai_api_key_here

# AI Service forward target to log received bookings on the backend.
BACKEND_FORWARD_URL=http://localhost:8080/api/new-booking
