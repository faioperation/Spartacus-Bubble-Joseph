# Application configuration
PORT=8080
NODE_ENV=development
BACKEND_URL=http://localhost:8000
FRONT_END_URL=http://localhost:5173

# JWT authentication configuration
JWT_SECRET_TOKEN=your_jwt_secret_token_here
JWT_REFRESH_TOKEN=your_jwt_refresh_token_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# Database configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Redis configuration
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=your_redis_host_here
REDIS_PORT=6379
REDIS_URL=redis://default:your_redis_password_here@your_redis_host_here:6379

# SendGrid email service configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=your_email@example.com

# Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8080/api/user/auth/google/callback

# AI Engine configuration (Teammate's Python API)
AI_ENGINE_URL=http://localhost:8007

# Rezgo configuration
REZGO_CID=your_rezgo_cid_here
REZGO_API_KEY=your_rezgo_api_key_here

# Stripe configuration
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
